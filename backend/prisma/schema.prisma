generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 사용자 ====================

model User {
  id            String    @id @default(uuid())
  username      String    @unique @db.VarChar(50)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  name          String    @db.VarChar(100)
  role          UserRole  @default(VIEWER)
  isActive      Boolean   @default(true) @map("is_active")
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  createdSubstations     Substation[]     @relation("SubstationCreatedBy")
  updatedSubstations     Substation[]     @relation("SubstationUpdatedBy")
  createdFloors          Floor[]          @relation("FloorCreatedBy")
  updatedFloors          Floor[]          @relation("FloorUpdatedBy")
  createdCables          Cable[]          @relation("CableCreatedBy")
  updatedCables          Cable[]          @relation("CableUpdatedBy")
  createdHeadquarters    Headquarters[]   @relation("HeadquartersCreatedBy")
  updatedHeadquarters    Headquarters[]   @relation("HeadquartersUpdatedBy")
  createdBranches        Branch[]         @relation("BranchCreatedBy")
  updatedBranches        Branch[]         @relation("BranchUpdatedBy")
  createdMaintenanceLogs MaintenanceLog[] @relation("MaintenanceLogCreatedBy")
  updatedMaintenanceLogs MaintenanceLog[] @relation("MaintenanceLogUpdatedBy")
  createdFiberPaths      FiberPath[]      @relation("FiberPathCreator")
  updatedFiberPaths      FiberPath[]      @relation("FiberPathUpdater")
  createdRackPresets     RackPreset[]     @relation("RackPresetCreatedBy")
  updatedRackPresets     RackPreset[]     @relation("RackPresetUpdatedBy")
  createdAssets          Asset[]          @relation("AssetCreatedBy")
  updatedAssets          Asset[]          @relation("AssetUpdatedBy")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum UserRole {
  ADMIN
  VIEWER
}

// ==================== 본부/지사 ====================

model Headquarters {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  createdBy User?    @relation("HeadquartersCreatedBy", fields: [createdById], references: [id])
  updatedBy User?    @relation("HeadquartersUpdatedBy", fields: [updatedById], references: [id])
  branches  Branch[]

  @@map("headquarters")
}

model Branch {
  id             String   @id @default(uuid())
  headquartersId String   @map("headquarters_id")
  name           String   @db.VarChar(100)
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    String?  @map("created_by")
  updatedById    String?  @map("updated_by")

  headquarters Headquarters @relation(fields: [headquartersId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("BranchCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?        @relation("BranchUpdatedBy", fields: [updatedById], references: [id])
  substations  Substation[]

  @@unique([headquartersId, name])
  @@map("branches")
}

// ==================== 변전소/층 ====================

model Substation {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  branchId    String?  @map("branch_id")
  address     String?  @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  branch    Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("SubstationCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("SubstationUpdatedBy", fields: [updatedById], references: [id])
  floors    Floor[]
  assets    Asset[]

  @@map("substations")
}

// ==================== 층(Floor) = 도면 ====================
// Floor가 캔버스이자 도면 단위. 통신실/UPS실 같은 영역 구분은
// 임포트한 backgroundDrawing의 라벨로 시각적으로 표현된다.

model Floor {
  id                String   @id @default(uuid())
  substationId      String   @map("substation_id")
  name              String   @db.VarChar(100)
  floorNumber       String?  @map("floor_number") @db.VarChar(20)
  description       String?  @db.Text
  sortOrder         Int      @default(0) @map("sort_order")
  isActive          Boolean  @default(true) @map("is_active")
  // 도면 속성
  canvasWidth       Int      @default(2000) @map("canvas_width")
  canvasHeight      Int      @default(1500) @map("canvas_height")
  gridSize          Int      @default(10) @map("grid_size")
  majorGridSize     Int      @default(60) @map("major_grid_size")
  backgroundColor   String   @default("#ffffff") @map("background_color") @db.VarChar(20)
  version           Int      @default(1)
  scaleRatio        Float?   @map("scale_ratio")
  asBuiltSnapshotId String?  @map("as_built_snapshot_id")
  // 임포트된 DWG 배경 (윤곽 + 라벨)
  backgroundDrawing Json?    @map("background_drawing")
  backgroundOpacity Float    @default(0.3) @map("background_opacity")
  // timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       String?  @map("created_by")
  updatedById       String?  @map("updated_by")

  substation Substation @relation(fields: [substationId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("FloorCreatedBy", fields: [createdById], references: [id])
  updatedBy  User?      @relation("FloorUpdatedBy", fields: [updatedById], references: [id])
  assets     Asset[]

  @@unique([substationId, name])
  @@map("floors")
}

// ==================== 랙 프리셋 (사용자 CRUD) ====================
// modules: [{ slotIndex, slotSpan, categoryCode, defaultName }]

model RackPreset {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(30)
  name         String   @db.VarChar(100)
  totalU       Int      @map("total_u")
  canvasWidth  Float    @map("canvas_width")
  canvasHeight Float    @map("canvas_height")
  modules      Json
  description  String?  @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  String?  @map("created_by")
  updatedById  String?  @map("updated_by")

  createdBy User? @relation("RackPresetCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("RackPresetUpdatedBy", fields: [updatedById], references: [id])

  @@map("rack_presets")
}

// ==================== 케이블 카테고리 (16종 시드) ====================

model CableCategory {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(30) // 'CBL-FCV' 등
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  displayColor String?  @map("display_color") @db.VarChar(7)
  displayGroup String?  @map("display_group") @db.VarChar(20) // 전원|접지|네트워크|광|제어
  iconName     String?  @map("icon_name") @db.VarChar(30)
  unit         String?  @db.VarChar(20)
  specTemplate Json?    @map("spec_template")
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cables Cable[]

  @@map("cable_categories")
}

// ==================== BOM 자재 (시공 보고서 전용) ====================
// 사용자에게 노출되지 않는 부속자재. 34개 시드.
// Parent-child 트리 구조 유지 (PIPE > PIPE-PVC 등)

model BomMaterial {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(30) // 'ACC-PIPE-PVC' 등
  name         String   @db.VarChar(100)
  parentId     String?  @map("parent_id")
  description  String?  @db.Text
  iconName     String?  @map("icon_name") @db.VarChar(30)
  unit         String?  @db.VarChar(20)
  specTemplate Json?    @map("spec_template")
  displayColor String?  @map("display_color") @db.VarChar(7)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parent   BomMaterial?  @relation("BomMaterialHierarchy", fields: [parentId], references: [id])
  children BomMaterial[] @relation("BomMaterialHierarchy")

  @@map("bom_materials")
}

// ==================== 포트 ====================

model Port {
  id            String   @id @default(uuid())
  equipmentId   String   @map("equipment_id")
  name          String   @db.VarChar(50)
  portType      PortType @map("port_type")
  portNumber    Int?     @map("port_number")
  label         String?  @db.VarChar(100)
  speed         String?  @db.VarChar(50)
  connectorType String?  @map("connector_type") @db.VarChar(50)
  description   String?  @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  equipment Asset @relation("PortAsset", fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, name])
  @@map("ports")
}

enum PortType {
  AC
  DC
  LAN
  FIBER
  CONSOLE
  USB
  OTHER
}

// ==================== 케이블 (다형 endpoint) ====================
// 각 side 한 쪽만 NOT NULL — CHECK constraint로 강제
// RACK kind Equipment 는 endpoint 불가 (service validation)
// OFD endpoint 는 fiberPathId + fiberPortNumber 필수 (service validation)

model Cable {
  id            String @id @default(uuid())
  // 통합 노드 모델(단계4c) — endpoint = 단일 Asset 노드 (필수).
  sourceAssetId String @map("source_asset_id")
  targetAssetId String @map("target_asset_id")

  cableType  CableType @map("cable_type")
  categoryId String?   @map("category_id") // CableCategory FK
  specParams Json?     @map("spec_params")
  pathPoints Json?     @map("path_points")

  // OFD 광경로 식별
  fiberPathId     String? @map("fiber_path_id")
  fiberPortNumber Int?    @map("fiber_port_number")

  label        String? @db.VarChar(100)
  length       Float?
  pathLength   Float?  @map("path_length")
  bufferLength Float   @default(4) @map("buffer_length")
  totalLength  Float?  @map("total_length")
  color        String? @db.VarChar(50)
  description  String? @db.Text

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  sourceAsset Asset          @relation("CableSourceAsset", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  targetAsset Asset          @relation("CableTargetAsset", fields: [targetAssetId], references: [id], onDelete: Cascade)
  fiberPath   FiberPath?     @relation("CableFiberPath", fields: [fiberPathId], references: [id], onDelete: SetNull)
  category    CableCategory? @relation(fields: [categoryId], references: [id])
  createdBy   User?          @relation("CableCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?          @relation("CableUpdatedBy", fields: [updatedById], references: [id])

  @@map("cables")
}

enum CableType {
  AC
  DC
  LAN
  FIBER
  GROUND
}

// ==================== 광경로 (변전소간 OFD 연결) ====================

model FiberPath {
  id          String   @id @default(uuid())
  ofdAId      String   @map("ofd_a_id")
  ofdBId      String   @map("ofd_b_id")
  portCount   Int      @map("port_count") // 24 or 48
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")

  ofdA      Asset   @relation("FiberPathOfdA", fields: [ofdAId], references: [id], onDelete: Cascade)
  ofdB      Asset   @relation("FiberPathOfdB", fields: [ofdBId], references: [id], onDelete: Cascade)
  cables    Cable[] @relation("CableFiberPath")
  createdBy User?   @relation("FiberPathCreator", fields: [createdById], references: [id])
  updatedBy User?   @relation("FiberPathUpdater", fields: [updatedById], references: [id])

  @@unique([ofdAId, ofdBId])
  @@map("fiber_paths")
}

// ==================== 설비 사진 ====================

model EquipmentPhoto {
  id          String    @id @default(uuid())
  equipmentId String    @map("equipment_id")
  side        String    @db.VarChar(10) // 'front' | 'rear'
  imageUrl    String    @map("image_url") @db.VarChar(500)
  description String?   @db.Text
  takenAt     DateTime? @map("taken_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  equipment Asset @relation("EquipmentPhotoAsset", fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("equipment_photos")
}

// ==================== 유지보수 이력 ====================

model MaintenanceLog {
  id          String    @id @default(uuid())
  equipmentId String    @map("equipment_id")
  logType     String    @db.VarChar(20) // MAINTENANCE, FAILURE, REPAIR
  title       String    @db.VarChar(200)
  description String?   @db.Text
  logDate     DateTime? @map("log_date") @db.Date
  severity    String?   @db.VarChar(20) // LOW, MEDIUM, HIGH, CRITICAL
  status      String    @default("OPEN") @db.VarChar(20) // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by")
  updatedById String?   @map("updated_by")

  equipment Asset @relation("MaintenanceLogAsset", fields: [equipmentId], references: [id], onDelete: Cascade)
  createdBy User? @relation("MaintenanceLogCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("MaintenanceLogUpdatedBy", fields: [updatedById], references: [id])

  @@map("maintenance_logs")
}

// ==================== 이력 ====================

model AuditLog {
  id            String   @id @default(uuid())
  entityType    String   @map("entity_type") @db.VarChar(50)
  entityId      String   @map("entity_id")
  entityName    String?  @map("entity_name") @db.VarChar(200)
  action        String   @db.VarChar(20) // CREATE, UPDATE, DELETE, MOVE
  actionDetail  String?  @map("action_detail") @db.VarChar(100)
  oldValues     Json?    @map("old_values")
  newValues     Json?    @map("new_values")
  changedFields String[] @map("changed_fields")
  context       Json? // 추가 컨텍스트 정보
  userId        String?  @map("user_id")
  userName      String?  @map("user_name") @db.VarChar(100)
  ipAddress     String?  @map("ip_address") @db.VarChar(50)
  userAgent     String?  @map("user_agent") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ==================== 자산 레지스터 (1단계, 가산) ====================
// Asset = 대장 레코드(SSOT). 도면 배치/랙 실장/속성은 전부 선택 필드.
// 생성 필수: substationId + assetTypeId + name.

// 설정/시드 관리 테이블 — createdById/updatedById 감사 필드 없음(의도적).
model AssetType {
  id               String   @id @default(uuid())
  code             String   @unique @db.VarChar(30)
  name             String   @db.VarChar(100)
  group            String?  @map("group_name") @db.VarChar(20)
  isContainer      Boolean  @default(false) @map("is_container")
  placementKind    String?  @map("placement_kind") @db.VarChar(20) // 'RACK'|'OFD'|'DIST'|'GROUNDING'|'HVAC'|null(모듈/장치)
  defaultSlotSpan  Int      @default(1) @map("default_slot_span")
  fieldTemplate    Json?    @map("field_template")
  requiredToCreate Json?    @map("required_to_create")
  iconName         String?  @map("icon_name") @db.VarChar(30)
  displayColor     String?  @map("display_color") @db.VarChar(7)
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_types")
}

model Asset {
  id            String    @id @default(uuid())
  substationId  String    @map("substation_id")
  assetTypeId   String    @map("asset_type_id")
  name          String    @db.VarChar(100)
  parentAssetId String?   @map("parent_asset_id")
  roomText      String?   @map("room_text") @db.VarChar(100)
  floorId       String?   @map("floor_id")
  positionX     Float?    @map("position_x_2d")
  positionY     Float?    @map("position_y_2d")
  width2d       Float?    @map("width_2d")
  height2d      Float?    @map("height_2d")
  rotation      Int       @default(0)
  slotIndex     Int?      @map("slot_index")
  slotSpan      Int?      @map("slot_span")
  totalU        Int?      @map("total_u")
  attributes    Json?
  installDate   DateTime? @map("install_date") @db.Date
  warrantyUntil DateTime? @map("warranty_until") @db.Date
  replaceDue    DateTime? @map("replace_due") @db.Date
  manager       String?   @db.VarChar(100)
  description   String?   @db.Text
  status        String?   @db.VarChar(20)
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdById   String?   @map("created_by")
  updatedById   String?   @map("updated_by")

  substation Substation @relation(fields: [substationId], references: [id], onDelete: Cascade)
  assetType  AssetType  @relation(fields: [assetTypeId], references: [id])
  parent     Asset?     @relation("AssetTree", fields: [parentAssetId], references: [id], onDelete: Cascade)
  children   Asset[]    @relation("AssetTree")
  floor      Floor?     @relation(fields: [floorId], references: [id], onDelete: SetNull)
  createdBy  User?      @relation("AssetCreatedBy", fields: [createdById], references: [id])
  updatedBy  User?      @relation("AssetUpdatedBy", fields: [updatedById], references: [id])

  sourceCablesAsset Cable[]          @relation("CableSourceAsset")
  targetCablesAsset Cable[]          @relation("CableTargetAsset")
  ports             Port[]           @relation("PortAsset")
  fiberPathsAsA     FiberPath[]      @relation("FiberPathOfdA")
  fiberPathsAsB     FiberPath[]      @relation("FiberPathOfdB")
  maintenanceLogs   MaintenanceLog[] @relation("MaintenanceLogAsset")
  photos            EquipmentPhoto[] @relation("EquipmentPhotoAsset")

  @@index([substationId])
  @@index([assetTypeId])
  @@index([parentAssetId])
  @@index([warrantyUntil])
  @@index([replaceDue])
  @@map("assets")
}
