# Production .env template — copy to .env on the air-gapped server before
# `podman-compose -f docker-compose.prod.yml up -d`.
#
# All JWT_* / DB_PASSWORD / CORS_ORIGIN values MUST be replaced with
# real production values. Generate JWT secrets with e.g.
#   openssl rand -hex 32

# ── Database ────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=__CHANGE_ME_STRONG_DB_PASSWORD__
DB_NAME=ict_digital_twin

# ── JWT (32+ random hex chars each) ─────────────────────────────
JWT_ACCESS_SECRET=__CHANGE_ME_LONG_RANDOM_HEX__
JWT_REFRESH_SECRET=__CHANGE_ME_LONG_RANDOM_HEX_DIFFERENT__
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Network ─────────────────────────────────────────────────────
# Frontend (nginx) is the only externally exposed port.
FRONTEND_PORT=80

# Origin allowed by backend CORS — set to whatever URL the user types
# in the browser (host or domain).
# Example: http://10.20.30.40   or   https://twin.kepco.local
CORS_ORIGIN=http://localhost
